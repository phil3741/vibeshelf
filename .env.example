# vibeshelf Configuration
# All integrations are OPTIONAL. The presence of env vars determines which features are active.
# Uncomment and fill in only what you need.

# ── Spotify (optional) ──────────────────────────────
# Get credentials from: https://developer.spotify.com/dashboard
# Without these, Spotify export and playback features are disabled.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888
# SPOTIFY_SP_DC=                  # Browser cookie for external playlist access (advanced)

# ── Navidrome (optional) ────────────────────────────
# Connect to a Navidrome/Subsonic server for library browsing and playback.
# NAVIDROME_URL=http://navidrome:4533
# NAVIDROME_USER=
# NAVIDROME_PASSWORD=
# NAVIDROME_EXTERNAL_URL=https://music.example.com

# ── Koito (optional) ────────────────────────────────
# PostgreSQL DSN for Koito scrobble history.
# Falls back to Spotify recently played data if not configured.
# KOITO_DSN=postgresql://user:pass@host:5432/koitodb
# KOITO_USER_ID=1

# ── Notifications (optional) ────────────────────────
# Gotify server URL for push notifications on export errors.
# Requires a token file mounted at /run/secrets/gotify.
# GOTIFY_URL=https://gotify.example.com

# ── General ─────────────────────────────────────────
# WEB_PORT=8080
# EXPORT_DIR=exports
# TZ=Europe/Vienna
